# AI Video Producer — credentials
#
# Copy to ~/.config/ai-video-producer/.env (recommended) and fill in.
# The /setup-credentials command will create that file for you and add a
# loader line to your shell profile so the values are present in every
# shell that launches Claude Code.

# fal.ai — used by the hosted MCP server at https://mcp.fal.ai/mcp
# Get one at https://fal.ai/dashboard/keys
FAL_KEY=

# Replicate — used by the local replicate-mcp npm package (stdio)
# Get one at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# WaveSpeedAI — used by runners/wavespeed_run.py
# Get one at https://wavespeed.ai/accesskey
WAVESPEED_API_KEY=

# MiniMax — used by the bundled minimax-mcp server (uvx)
# Region matters: key + host must match.
#   Global:   key from https://www.minimax.io/platform/user-center/basic-information/interface-key
#             host = https://api.minimax.io
#   Mainland: key from https://platform.minimaxi.com/user-center/basic-information/interface-key
#             host = https://api.minimaxi.com
MINIMAX_API_KEY=
MINIMAX_API_HOST=https://api.minimax.io
# Where MiniMax should write generated media when MINIMAX_API_RESOURCE_MODE=local
MINIMAX_MCP_BASE_PATH=$HOME/Videos/minimax
# url (default) returns hosted URLs; local downloads to MINIMAX_MCP_BASE_PATH
MINIMAX_API_RESOURCE_MODE=url

# Optional: ElevenLabs (only if you add an ElevenLabs MCP later)
# ELEVENLABS_API_KEY=

# Optional: OpenAI (for OpenAI TTS / Sora-class models if added later)
# OPENAI_API_KEY=
